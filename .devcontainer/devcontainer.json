{
  "name": "Softnet",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "postCreateCommand": "pip install -e . && cd frontend && npm install && npm run build",
  "postStartCommand": "nohup python run.py --no-browser --port 8000 > /tmp/softnet.log 2>&1 &",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Softnet",
      "onAutoForward": "openBrowser"
    }
  }
}
